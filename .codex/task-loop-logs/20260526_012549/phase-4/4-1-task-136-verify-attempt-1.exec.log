   309	        failure: CoreErrorMappingSnapshot?,
   310	        undoStore: any CoreUndoActionLogging,
   311	        errorMapper: any CoreErrorMapping
   312	    ) async -> BatchTagUndoState? {
   313	        guard failure == nil, let report, report.shouldRefreshUndoActionLogAfterApply else { return nil }
   314	        guard let token = normalizedToken(report.undoToken) else {
   315	            return .unavailable(reason: "Undo is unavailable for this import conflict result.")
   316	        }
