   287	            return BatchTagUndoLoadResult(
   288	                action: action,
   289	                unavailableReason: disabledReason(for: action),
   290	                failure: nil
   291	            )
   292	        }
   293	        return BatchTagUndoLoadResult(action: action, unavailableReason: nil, failure: nil)
   294	    }
   295	
   296	    private static func disabledReason(for action: UndoActionRecordSnapshot) -> String {
   297	        if let reason = action.disabledReason, !reason.isEmpty { return reason }
   298	        switch action.status {
   299	        case .blocked:
   300	            return "Undo action is currently blocked."
   301	        case .expired:
   302	            return "Undo action expired."
   303	        case .executed:
   304	            return "Undo action has already been executed."
   305	        case .pending:
   306	            return "Undo action is currently unavailable."
   307	        }
   308	    }
