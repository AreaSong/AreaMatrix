   688	    return ["swiftlint", "lint", "--strict", "--config", config, "--force-exclude", ".", "--no-cache"]
   689	
   690	
   691	def _run_swift_checks(root: Path) -> int:
   692	    macos_dir = root / "apps/macos"
   693	    require_command("swiftformat")
   694	    require_command("swiftlint")
   695	    for argv in [_swiftformat_lint_args(root), _swiftlint_lint_args(root)]:
   696	        proc = run_step(argv, cwd=macos_dir, check=False)
   697	        if proc.returncode != 0:
   698	            return proc.returncode
   699	    return 0
   700	
   701	
   702	def _missing_macos_rust_targets() -> list[str]:
   703	    required_targets = ["aarch64-apple-darwin", "x86_64-apple-darwin"]
   704	    if shutil.which("rustup") is None:
   705	        return []
   706	    proc = subprocess.run(
   707	        ["rustup", "target", "list", "--installed"],
   708	        text=True,
   709	        stdout=subprocess.PIPE,
   710	        stderr=subprocess.PIPE,
   711	        check=False,
   712	    )
   713	    if proc.returncode != 0:
   714	        print("ERROR: unable to list installed Rust targets.", file=os.sys.stderr)
   715	        if proc.stderr.strip():
   716	            print(proc.stderr.strip(), file=os.sys.stderr)
   717	        return required_targets
   718	    installed = {line.strip() for line in proc.stdout.splitlines()}
   719	    return [target for target in required_targets if target not in installed]
   720	
   721	
   722	def _run_macos_prerequisites_check() -> int:
   723	    failures = FailureCollector()
   724	    missing_targets = _missing_macos_rust_targets()
   725	    for target in missing_targets:
   726	        failures.fail(f"missing Rust target '{target}'; install with: rustup target add {target}")
   727	
   728	    for tool in ["swiftformat", "swiftlint"]:
   729	        if shutil.which(tool) is None:
   730	            failures.fail(f"missing command '{tool}' in PATH; install it before running macOS checks")
   731	
   732	    if failures.count:
   733	        print(
   734	            f"macOS prerequisite check: FAILED ({failures.count} issue(s))",
   735	            file=os.sys.stderr,
   736	        )
   737	        return 1
   738	    print("macOS prerequisite check: OK")
   739	    return 0
   740	
   741	
   742	def _run_macos_checks(root: Path) -> int:
   743	    macos_dir = root / "apps/macos"
   744	    macos_project = macos_dir / "AreaMatrix.xcodeproj"
   745	    if not macos_dir.is_dir():
   746	        print()
   747	        print("==> Skipping macOS checks")
   748	        print(f"    {macos_dir} does not exist yet.")
   749	        return 0
   750	    if macos_project.is_dir():
   751	        rc = _run_macos_prerequisites_check()
   752	        if rc != 0:
   753	            return rc
   754	        out_dir = Path(os.environ.get("AREAMATRIX_CHECK_CORE_OUT_DIR", "/private/tmp/areamatrix-check-all/Bridge/UniFFI"))
   755	        rc = run_core_build(root, out_dir=out_dir)
   756	        if rc != 0:
   757	            return rc
   758	        rc = run_macos_tests(root)
   759	        if rc != 0:
   760	            return rc
   761	    else:
   762	        print()
   763	        print("==> Skipping Xcode build and test")
   764	        print(f"    {macos_project} does not exist yet.")
   765	    return _run_swift_checks(root)
   766	
   767	
   768	def run_all_check(root: Path | None = None) -> int:
   769	    root = (root or project_root()).resolve()
   770	    steps = [
   771	        ("governance", lambda: run_governance_check(root)),
   772	        ("skills", lambda: run_skills_check(root)),
   773	        ("task-loop", lambda: run_task_loop_check(root)),
   774	        ("prompt doctor", lambda: run_prompts_check(root)),
   775	        ("diff check", lambda: run_diff_check(root)),
   776	        ("core checks", lambda: _run_core_checks(root)),
   777	        ("macOS checks", lambda: _run_macos_checks(root)),
   778	    ]
   779	    for label, func in steps:
   780	        print()
   781	        print(f"==> ./dev check all: {label}", flush=True)
   782	        rc = func()
   783	        if rc != 0:
   784	            return rc
