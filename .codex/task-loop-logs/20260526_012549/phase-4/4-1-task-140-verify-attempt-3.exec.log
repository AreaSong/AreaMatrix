   345	                    Text("已添加")
   346	                        .foregroundStyle(.secondary)
   347	                } else {
   348	                    Text("\(tag.fileCount)")
   349	                        .foregroundStyle(.secondary)
   350	                }
   351	            }
   352	        }
   353	        .disabled(tag.selected || tag.disabled)
   354	    }
   355	}

