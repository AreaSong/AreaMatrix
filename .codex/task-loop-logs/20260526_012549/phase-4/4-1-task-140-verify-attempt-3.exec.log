   239	    private static func updateDraft(
   240	        suggestionID: String,
   241	        in state: DetailTagSuggestionState,
   242	        disabledReason: String?,
   243	        update: (inout TagSuggestionEditDraft) -> Void
   244	    ) -> DetailTagSuggestionState {
   245	        guard let report = state.report, var session = state.editSession else { return state }
   246	        guard let index = session.drafts.firstIndex(where: { $0.suggestionID == suggestionID }) else { return state }
   247	        update(&session.drafts[index])
   248	        return .editing(
   249	            fileID: report.fileID,
   250	            report,
   251	            validatedSession(session, report: report, disabledReason: disabledReason)
   252	        )
   253	    }
   254	
   255	    private static func validatedSession(
   256	        _ session: TagSuggestionEditSession,
   257	        report: TagSuggestionReportSnapshot,
   258	        disabledReason: String?
   259	    ) -> TagSuggestionEditSession {
   260	        var seenSlugs: Set<String> = []
   261	        var next = session
   262	        next.drafts = session.drafts.map { draft in
   263	            var updated = draft
   264	            updated.status = status(for: draft, seenSlugs: &seenSlugs, report: report, disabledReason: disabledReason)
   265	            return updated
   266	        }
   267	        return next
   268	    }
   269	
   270	    private static func status(
   271	        for draft: TagSuggestionEditDraft,
   272	        seenSlugs: inout Set<String>,
   273	        report: TagSuggestionReportSnapshot,
   274	        disabledReason: String?
   275	    ) -> TagSuggestionEditRowStatus {
   276	        if disabledReason != nil { return .blocked("Tag store is read-only.") }
   277	        guard let suggestion = report.suggestions.first(where: { $0.suggestionID == draft.suggestionID }) else {
   278	            return .blocked("Suggestion is no longer available.")
   279	        }
   280	        if suggestion.status == .alreadyAdded { return .alreadyAdded("Already added") }
   281	        if suggestion.status == .blocked || suggestion.disabledReason != nil {
   282	            return .blocked(suggestion.disabledReason ?? "Suggestion is blocked.")
   283	        }
   284	        guard let normalized = TagInputNormalization.normalizedValue(draft.slug) else {
   285	            return .invalid(TagInputNormalization.invalidMessage)
   286	        }
   287	        if seenSlugs.contains(normalized) { return .duplicate("Duplicate slug in selected tags.") }
   288	        seenSlugs.insert(normalized)
   289	        if report.tagSet.containsFileTag(value: normalized) { return .alreadyAdded("Already added") }
   290	        return .ready
   291	    }
   292	
   293	    private static func normalizedSlug(from displayName: String) -> String {
   294	        displayName
   295	            .trimmingCharacters(in: .whitespacesAndNewlines)
   296	            .lowercased()
   297	            .replacingOccurrences(of: " ", with: "-")
   298	    }
   299	}

