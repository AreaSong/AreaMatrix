   432	    private func refreshAfterExternalRemovedSync(
   433	        _ event: MainExternalCreatedFileEvent,
   434	        result: SyncResultSnapshot
   435	    ) async throws -> Int64? {
   436	        let removedFileID = selectedFileIDForExternalRemoval(path: event.relativePath)
   437	        let removedSnapshot = removedFileID.flatMap { missingSnapshot(fileID: $0, fallbackPath: event.relativePath) }
   438	        let loadedFiles = try await reloadFilesForExternalSync()
   439	        if removedFileID == nil {
   440	            return nil
   441	        }
   442	        guard result.detectedDeletes > 0 else {
   443	            throw CoreError.Internal(
   444	                message: "removed event \(event.fsEventID) did not report a detected delete: \(event.relativePath)"
   445	            )
   446	        }
   447	        guard let removedFileID else { return nil }
   448	
   449	        files = loadedFiles.filter { $0.id != removedFileID }
   450	        selection = .single(removedFileID)
   451	        selectedFileDetail = removedSnapshot
   452	        selectedFileNoteWriteBlock = removedSnapshot.flatMap { noteWriteBlock(for: $0) }
   453	        detailErrorMapping = CoreErrorMappingSnapshot.missingFromExternalChange(fileID: removedFileID)
   454	        isDetailLoading = false
   455	        detailTagEditorState = .notLoaded
   456	        detailTagSuggestionState = .idle
   457	        statusBanner = .removedSelectedFile(fileID: removedFileID)
   458	        return removedFileID
   459	    }
   460	
   461	    private func reloadFilesForExternalSync() async throws -> [FileEntrySnapshot] {
   462	        isLoading = true
   463	        do {
   464	            let loadedFiles = try await fileLister.listFiles(
   465	                repoPath: repoPath,
   466	                filter: .currentCategory(currentCategory)
   467	            )
   468	            files = loadedFiles
   469	            errorMapping = nil
   470	            isLoading = false
   471	            return loadedFiles
   472	        } catch {
   473	            errorMapping = await mapCoreError(error)
   474	            isLoading = false
   475	            throw error
   476	        }
   477	    }
   478	
   479	    func clearDetail() {
   480	        detailGeneration += 1
   481	        selection = .none
   482	        selectedFileDetail = nil; selectedFileNoteWriteBlock = nil; detailErrorMapping = nil
   483	        detailTagEditorState = .notLoaded
   484	        detailTagSuggestionState = .idle
   485	        clearTagFilterRegistry()
   486	        isDetailLoading = false
   487	        resetDetailLog()
   488	        pendingActionDestination = nil; renameState = .idle; deleteState = .idle; changeCategoryState = .idle
   489	    }
