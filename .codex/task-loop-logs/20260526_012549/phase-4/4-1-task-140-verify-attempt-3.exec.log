   301	        report: TagSuggestionApplyReportSnapshot
   302	    ) -> TagSuggestionEditSession {
   303	        var next = session
   304	        next.drafts = session.drafts.map { draft in
   305	            var updated = draft
   306	            guard let result = report.itemResults.first(where: { $0.suggestionID == draft.suggestionID }) else {
   307	                return updated
   308	            }
   309	            switch result.status {
   310	            case .applied:
   311	                updated.status = .applied
   312	            case .alreadyAdded:
   313	                updated.status = .alreadyAdded(result.error ?? "Already added")
   314	            case .failed:
   315	                updated.status = .blocked(result.error ?? "A suggestion could not be applied.")
   316	            }
   317	            return updated
   318	        }
   319	        return next
   320	    }
