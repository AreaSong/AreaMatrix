   180	    static func shouldClearSubmittedQuery(submittedTag: String, state: DetailTagEditorState) -> Bool {
   181	        let normalizedTag = submittedTag.trimmingCharacters(in: .whitespacesAndNewlines)
   182	        guard case let .loaded(_, tagSet) = state, !normalizedTag.isEmpty else { return false }
   183	        return tagSet.containsFileTag(value: normalizedTag)
   184	    }
   185	}
