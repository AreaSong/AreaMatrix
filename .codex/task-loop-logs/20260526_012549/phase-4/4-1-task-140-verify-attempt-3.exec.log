   215	    let disabledReason: MainFileWriteActionDisabledReason?
   216	    let onRetry: () -> Void
   217	    let onAddTag: (String) -> Void
   218	    let onOpenSuggestions: () -> Void
   219	    let onClose: () -> Void
   220	
   221	    @FocusState private var isInputFocused: Bool
   222	
   223	    var body: some View {
   224	        VStack(alignment: .leading, spacing: 10) {
   225	            TextField("Search or create tag...", text: $query)
   226	                .textFieldStyle(.roundedBorder)
   227	                .focused($isInputFocused)
   228	                .disabled(disabledReason != nil)
   229	                .onSubmit(performSubmit)
   230	                .accessibilityIdentifier("S2-07-tag-search-create")
   231	            if shouldShowValidationMessage, let tagValidationMessage {
   232	                Text(tagValidationMessage)
   233	                    .font(.caption)
   234	                    .foregroundStyle(.secondary)
   235	            }
   236	            popoverStatus
   237	            tagList
   238	            HStack {
   239	                Button("Suggestions...", action: onOpenSuggestions)
   240	                    .accessibilityIdentifier("S2-23-C2-19-open-tag-suggestions")
   241	                Spacer()
   242	                Button("Close", action: onClose)
   243	            }
   244	        }
   245	        .padding(12)
   246	        .frame(width: 280)
   247	        .onAppear { isInputFocused = true }
   248	    }
   249	
   250	    @ViewBuilder
   251	    private var popoverStatus: some View {
   252	        if state.isLoading {
   253	            Text("Loading tags...")
   254	                .font(.caption)
   255	                .foregroundStyle(.secondary)
   256	        } else if let failure = state.failure {
   257	            HStack(spacing: 8) {
   258	                Text(failure.mapping.userMessage)
   259	                Button("Retry", action: onRetry)
   260	            }
   261	            .font(.caption)
   262	            .foregroundStyle(.secondary)
   263	        } else if let reason = disabledReason {
   264	            Text(reason.rawValue)
   265	                .font(.caption)
   266	                .foregroundStyle(.secondary)
   267	        }
   268	    }
   269	
   270	    private var tagList: some View {
   271	        VStack(alignment: .leading, spacing: 6) {
   272	            ForEach(candidateTags) { tag in
   273	                TagSuggestionRow(tag: tag) {
   274	                    guard !tag.selected, !tag.disabled else { return }
   275	                    onAddTag(tag.value)
   276	                }
   277	            }
   278	            if candidateTags.isEmpty {
   279	                Text(state.tagSet == nil ? "Could not load tags" : "No tags yet")
   280	                    .font(.callout)
   281	                    .foregroundStyle(.secondary)
   282	            }
   283	            if canCreateTag {
   284	                Button("Create \"\(normalizedQuery)\"") {
   285	                    onAddTag(normalizedQuery)
   286	                }
   287	            }
   288	        }
   289	    }
   290	
   291	    private var candidateTags: [TagRecordSnapshot] {
   292	        let tags = query.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty ?
   293	            state.tagSet?.recentTags ?? [] :
   294	            state.tagSet?.availableTags ?? []
   295	        let normalized = normalizedQuery
   296	        guard !normalized.isEmpty else { return tags }
   297	        return tags.filter { tag in
   298	            tag.value.localizedCaseInsensitiveContains(normalized) ||
   299	                tag.displayName.localizedCaseInsensitiveContains(normalized)
   300	        }
   301	    }
   302	
   303	    private var normalizedQuery: String {
   304	        query.trimmingCharacters(in: .whitespacesAndNewlines)
   305	    }
   306	
   307	    private var canCreateTag: Bool {
   308	        guard disabledReason == nil, !state.isLoading, tagValidationMessage == nil else { return false }
   309	        return state.tagSet?.availableTags.contains { tag in
   310	            tag.value.caseInsensitiveCompare(normalizedQuery) == .orderedSame
   311	        } == false
   312	    }
   313	
   314	    private var shouldShowValidationMessage: Bool {
   315	        !query.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty
   316	    }
   317	
   318	    private var tagValidationMessage: String? {
   319	        let tag = normalizedQuery
   320	        if tag.isEmpty { return "Tag is empty." }
   321	        if tag.count > 64 { return "Tag is too long." }
   322	        if tag.contains("/") || tag.contains(":") || tag.contains("\0") { return "Tag contains illegal characters." }
   323	        return nil
   324	    }
   325	
   326	    private func performSubmit() {
   327	        guard let first = candidateTags.first(where: { !$0.selected && !$0.disabled }) else {
   328	            if canCreateTag { onAddTag(normalizedQuery) }
   329	            return
   330	        }
   331	        onAddTag(first.value)
   332	    }
   333	}
