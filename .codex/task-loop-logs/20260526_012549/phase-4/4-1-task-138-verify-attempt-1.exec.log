   109	enum UndoHistoryActionLog {
   110	    static func load(
   111	        repoPath: String,
   112	        undoStore: any CoreUndoActionLogging,
   113	        redoStore: any CoreRedoActionLogging,
   114	        errorMapper: any CoreErrorMapping
   115	    ) async -> UndoHistoryState {
   116	        do {
   117	            return .loaded(try await loadSnapshot(repoPath: repoPath, undoStore: undoStore, redoStore: redoStore))
   118	        } catch {
   119	            return .failed(await mapError(error, errorMapper: errorMapper))
   120	        }
   121	    }
   122	
   123	    static func undoLatest(
   124	        repoPath: String,
   125	        snapshot: UndoHistorySnapshot,
   126	        undoStore: any CoreUndoActionLogging,
   127	        redoStore: any CoreRedoActionLogging,
   128	        errorMapper: any CoreErrorMapping
   129	    ) async -> UndoHistoryState {
   130	        guard let latest = snapshot.undoActions.first else { return .loaded(snapshot) }
   131	        guard latest.status == .pending, latest.canUndo else {
   132	            return .undoFailed(
   133	                unavailableMapping(reason: disabledReason(for: latest)),
   134	                previous: snapshot,
   135	                attempted: latest
   136	            )
   137	        }
   138	        do {
   139	            let result = try await undoStore.undoAction(repoPath: repoPath, actionID: latest.actionID)
   140	            do {
   140	            do {
   141	                let refreshed = try await loadSnapshot(repoPath: repoPath, undoStore: undoStore, redoStore: redoStore)
   142	                return .undone(result, refreshed: refreshed.markingUndoBlockedIfNeeded(result))
   143	            } catch {
   144	                return .refreshFailed(
   145	                    await mapError(error, errorMapper: errorMapper),
   146	                    previous: snapshot.markingUndoBlockedIfNeeded(result)
   147	                )
   148	            }
   149	        } catch {
   150	            return .undoFailed(await mapError(error, errorMapper: errorMapper), previous: snapshot, attempted: latest)
   151	        }
   152	    }
   153	
   154	    static func redoLatest(
   155	        repoPath: String,
   156	        snapshot: UndoHistorySnapshot,
   157	        undoStore: any CoreUndoActionLogging,
   158	        redoStore: any CoreRedoActionLogging,
   159	        errorMapper: any CoreErrorMapping
   160	    ) async -> UndoHistoryState {
   161	        guard let latest = snapshot.redoActions.first else { return .loaded(snapshot) }
   162	        guard latest.status == .available, latest.canRedo else {
   163	            return .redoFailed(unavailableRedoMapping(for: latest), previous: snapshot, attempted: latest)
   164	        }
   165	        do {
   166	            let result = try await redoStore.redoAction(repoPath: repoPath, actionID: latest.actionID)
   167	            do {
   168	                return .redone(result, refreshed: try await loadSnapshot(
   169	                    repoPath: repoPath,
   170	                    undoStore: undoStore,
   171	                    redoStore: redoStore
   172	                ))
   173	            } catch {
   174	                return .refreshFailed(await mapError(error, errorMapper: errorMapper), previous: snapshot)
   175	            }
   176	        } catch {
   177	            return .redoFailed(await mapError(error, errorMapper: errorMapper), previous: snapshot, attempted: latest)
   178	        }
   179	    }
   180	
   181	    static func action(
   182	        in actions: [UndoActionRecordSnapshot],
   183	        focusedActionID: String?
   184	    ) -> UndoActionRecordSnapshot? {
   185	        if let focusedActionID, let focused = actions.first(where: { $0.actionID == focusedActionID }) {
   186	            return focused
   187	        }
   188	        return actions.first
   189	    }
   190	
   191	    static func disabledReason(for action: UndoActionRecordSnapshot) -> String {
   192	        if action.status == .pending, action.canUndo { return "" }
   193	        if let reason = action.disabledReason, !reason.isEmpty { return reason }
   194	        switch action.status {
   195	        case .blocked:
   196	            return "Review details before undoing this action."
   197	        case .expired:
   198	            return "This action expired after app restart or later changes."
   199	        case .executed:
   200	            return "This action has already been undone."
   201	        case .pending:
   202	            return "Undo newer actions first."
   203	        }
   204	    }
