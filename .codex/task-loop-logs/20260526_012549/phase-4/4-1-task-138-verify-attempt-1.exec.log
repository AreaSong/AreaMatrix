   185	    @MainActor
   186	    private func undo(_ action: UndoActionRecordSnapshot) async {
   187	        undoState = .undoing(action)
   188	        actionLogRefreshFailure = nil
   189	        let applied = await BatchTagUndoAction.undo(
   190	            repoPath: repoPath,
   191	            action: action,
   192	            undoStore: undoStore,
   193	            errorMapper: errorMapper
   194	        )
   195	        if let failure = applied.failure {
   196	            undoState = .failed(failure, previous: action)
   197	            return
   198	        }
   199	        guard let result = applied.result else {
   200	            undoState = .unavailable(reason: "Undo action finished without a result.")
   201	            return
   202	        }
   203	
   204	        undoState = .undone(result)
   205	        await refreshAfterUndo(result)
   206	        await loadLatestRedoAction()
   207	    }
