   228	    private func loadLatestRedoAction() async {
   229	        let previous = redoState.action
   230	        redoState = .checking(previous: previous)
   231	        let loaded = await RedoActionFeedback.loadLatestAction(
   232	            repoPath: repoPath,
   233	            redoStore: redoStore,
   234	            errorMapper: errorMapper
   235	        )
   236	        redoState = loaded.feedbackState() ?? .idle
   237	        updateRedoSourceUndoAction(for: loaded.action)
