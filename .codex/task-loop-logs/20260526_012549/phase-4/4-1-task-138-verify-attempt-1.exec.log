   209	    @MainActor
   210	    private func refreshAfterUndo(_ result: UndoActionResultSnapshot) async {
   211	        let plan = BatchTagUndoRefreshPlan(refreshTargets: result.refreshTargets)
   212	        if plan.refreshesCurrentList { onRefreshCurrentList() }
   213	        if plan.refreshesSelectionDetails { onRefreshSelection() }
   214	        if plan.refreshesChangeLog { onRefreshChangeLog() }
   215	        guard plan.refreshesUndoActions else { return }
   216	
   217	        let refreshed = await BatchTagUndoAction.refreshActionLog(
   218	            repoPath: repoPath,
   219	            actionID: result.actionID,
   220	            undoStore: undoStore,
   221	            errorMapper: errorMapper
   222	        )
   223	        actionLogRefreshFailure = refreshed.failure
   224	        redoSourceUndoAction = refreshed.action
   225	    }
