   134	struct BatchAddTagsSheet: View {
   135	    let repoPath: String
   136	    let fileIDs: [Int64]
   137	    let selectedCount: Int
   138	    let disabledReason: String?
   139	    let tagStore: any CoreTagCRUD
   140	    let undoStore: any CoreUndoActionLogging
   141	    let errorMapper: any CoreErrorMapping
   142	    let onUndoStateChange: (BatchTagUndoState) -> Void
   143	    let onClose: () -> Void
   144	    @State private var draft = BatchAddTagsDraft()
   145	    @State private var catalogState: BatchTagCatalogState = .idle
   146	    @State private var isApplying = false
   147	    @State private var report: BatchMutationReportSnapshot?
   148	    @State private var failure: CoreErrorMappingSnapshot?
   149	    @State private var showsDetails = false
   150	
   151	    var body: some View {
   152	        MainFileActionSheetContainer(title: "批量添加标签", pageID: "S2-09") {
   153	            if selectedCount == 0 {
   154	                Text("No files selected")
   155	                    .foregroundStyle(.secondary)
   156	                HStack { Spacer(); Button("Close", action: onClose) }
   157	            } else {
   158	                BatchAddTagsSheetContent(
   159	                    selectedCount: selectedCount,
   160	                    disabledReason: disabledReason,
   161	                    draft: $draft,
   162	                    catalogState: catalogState,
   163	                    isApplying: isApplying,
   164	                    report: report,
   165	                    failure: failure,
   166	                    showsDetails: $showsDetails,
   167	                    onAddPendingTag: addPendingTag,
   168	                    onAddCandidateTag: addCandidateTag,
   169	                    onRetryCatalog: { Task { await loadTagCatalog() } },
   170	                    onApply: { Task { await apply() } },
   171	                    onCancel: onClose
   172	                )
   173	            }
   174	        }
   175	        .task(id: fileIDs) { await loadTagCatalog() }
   176	    }
   177	
   178	    private func addPendingTag() {
   179	        let state = BatchTagValidation.pendingStateAfterAdding(
   180	            input: draft.input,
   181	            pendingTags: draft.pendingTags,
   182	            catalog: catalogState.tagSet,
   183	            disabledReason: disabledReason
   184	        )
   185	        draft.apply(state)
   186	    }
   187	
   188	    private func addCandidateTag(_ tag: TagRecordSnapshot) {
   189	        let state = BatchTagValidation.pendingStateAfterAdding(
   190	            input: tag.value,
   191	            pendingTags: draft.pendingTags,
   192	            catalog: catalogState.tagSet,
   193	            disabledReason: tag.disabled ? "Tag store is read-only." : disabledReason
   194	        )
   195	        draft.apply(state)
   196	    }
   197	
   198	    @MainActor
   199	    private func loadTagCatalog() async {
   200	        let previous = catalogState.tagSet
   201	        catalogState = .loading(previous: previous)
   202	        let state = await BatchTagCatalogAction.load(
   203	            repoPath: repoPath,
   204	            fileIDs: fileIDs,
   205	            tagStore: tagStore,
   206	            errorMapper: errorMapper
   207	        )
   208	        switch state {
   209	        case let .failed(mapping, _):
   210	            catalogState = .failed(mapping, previous: previous)
   211	        default:
   212	            catalogState = state
   213	        }
   214	    }
   215	
   216	    @MainActor
   217	    private func apply() async {
   218	        guard BatchTagValidation.canApply(
   219	            isApplying: isApplying,
   220	            disabledReason: disabledReason,
   221	            input: draft.input,
   222	            pendingTags: draft.pendingTags,
   223	            fieldError: draft.fieldError,
   224	            selectedCount: selectedCount
   225	        ) else { return }
   226	        switch BatchTagValidation.normalizedTagsForApply(draft.pendingTags) {
   227	        case let .failure(message):
   228	            draft.fieldError = message
   229	        case let .success(tags):
   230	            await submit(tags: tags)
   231	        }
   232	    }
   233	
   234	    @MainActor
   235	    private func submit(tags: [String]) async {
   236	        isApplying = true; failure = nil; report = nil
   237	        onUndoStateChange(.idle)
   238	        let result = await BatchAddTagsAction.apply(
   239	            repoPath: repoPath,
   240	            fileIDs: fileIDs,
   241	            tags: tags,
   242	            tagStore: tagStore,
   243	            errorMapper: errorMapper
   244	        )
   245	        report = result.report; failure = result.failure; isApplying = false
   246	        let completion = await BatchTagUndoAction.completionAfterBatchApply(
   247	            repoPath: repoPath,
   248	            report: result.report,
   249	            failure: result.failure,
   250	            undoStore: undoStore,
   251	            errorMapper: errorMapper
   252	        )
   253	        if let undoState = completion.undoState {
   254	            onUndoStateChange(undoState)
   255	        }
   256	        if completion.closesSheet {
   257	            onClose()
   258	        }
   259	    }
   260	}

