   290	) {
   291	    XCTAssertTrue(preview.canApply)
   292	    XCTAssertEqual(preview.requestedFileCount, 2)
   293	    XCTAssertEqual(preview.willRenameCount, 1)
   294	    XCTAssertEqual(preview.displayOnlyCount, 1)
