   332	private actor S214BatchRenameRecordingUndoStore: CoreUndoActionLogging {
   333	    enum Result {
   334	        case list(Swift.Result<[UndoActionRecordSnapshot], Error>)
   335	        case undo(Swift.Result<UndoActionResultSnapshot, Error>)
   336	    }
   337	
   338	    private var results: [Result]
   339	    private var recordedListRequests: [String] = []
   340	    private var recordedUndoRequests: [String] = []
   341	
   342	    init(results: [Result]) {
   343	        self.results = results
