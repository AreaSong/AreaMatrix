   214	private struct S214IntegrationContext {
   215	    let repoURL: URL
   216	    let sourceRootURL: URL
   217	    let repoOwnedOriginalURL: URL
   218	    let repoOwnedRenamedURL: URL
   219	    let indexOnlySourceURL: URL
   220	    let bridge: CoreBridge
   221	    let repoOwned: FileEntrySnapshot
   222	    let indexOnly: FileEntrySnapshot
   223	
   224	    func cleanUp() {
   225	        try? FileManager.default.removeItem(at: repoURL)
   226	        try? FileManager.default.removeItem(at: sourceRootURL)
   227	    }
   228	}
   229	
   230	private func makeS214IntegrationContext() async throws -> S214IntegrationContext {
   231	    let repoURL = try makeImportSingleFileTemporaryDirectory(prefix: "s214-repo")
   232	    let sourceRootURL = try makeImportSingleFileTemporaryDirectory(prefix: "s214-source")
   233	    let repoOwnedSourceURL = sourceRootURL.appendingPathComponent("owned-source.pdf")
   234	    let indexOnlySourceURL = sourceRootURL.appendingPathComponent("indexed-source.pdf")
   235	    try Data("repo owned bytes".utf8).write(to: repoOwnedSourceURL)
   236	    try Data("indexed bytes".utf8).write(to: indexOnlySourceURL)
   237	
   238	    let bridge = CoreBridge()
   239	    try await bridge.initializeEmptyRepository(repoPath: repoURL.path)
   240	    let repoOwned = try await bridge.importCopiedFile(
   241	        repoPath: repoURL.path,
   242	        sourceURL: repoOwnedSourceURL,
   243	        overrideCategory: "docs",
   244	        overrideFilename: "owned.pdf",
   245	        duplicateStrategy: .skip
   246	    )
   247	    let indexOnly = try await bridge.importIndexedFile(
   248	        repoPath: repoURL.path,
   249	        sourceURL: indexOnlySourceURL,
   250	        overrideCategory: "docs",
   251	        overrideFilename: "indexed.pdf",
   252	        duplicateStrategy: .skip
   253	    )
   254	    return S214IntegrationContext(
   255	        repoURL: repoURL,
   256	        sourceRootURL: sourceRootURL,
   257	        repoOwnedOriginalURL: repoURL.appendingPathComponent(repoOwned.path),
   258	        repoOwnedRenamedURL: repoURL.appendingPathComponent("docs/owned_02.pdf"),
   259	        indexOnlySourceURL: indexOnlySourceURL,
   260	        bridge: bridge,
   261	        repoOwned: repoOwned,
   262	        indexOnly: indexOnly
   263	    )
   264	}
   265	
   266	private func makeS214Route(context: S214IntegrationContext) -> BatchRenameRoute {
   267	    let filesInListOrder = [context.indexOnly, context.repoOwned]
   268	    let summary = MultiSelectionDetailSummary(
   269	        selection: .multiple([context.repoOwned.id, context.indexOnly.id]),
   270	        files: filesInListOrder
   271	    )
   272	    return BatchRenameRoute(
   273	        source: .listContextMenu,
   274	        fileIDs: BatchRenameEntryPolicy.fileIDsForPreview(summary: summary),
   275	        selectedFiles: summary.files,
   276	        selectedCount: summary.selectedCount,
   277	        disabledReason: BatchRenameEntryPolicy.disabledReason(
   278	            selectedFiles: summary.files,
   279	            isReadOnly: false,
   280	            isLoading: false,
   281	            writeLockedFileIDs: []
   282	        )
   283	    )
   284	}
