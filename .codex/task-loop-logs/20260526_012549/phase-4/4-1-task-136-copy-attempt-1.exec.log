+
+        let action = UndoActionRecordSnapshot.s221IntegrationAction()
+        let undoResult = UndoActionResultSnapshot.s221IntegrationResult()
+        let undoStore = S221IntegrationUndoStore(results: [.list(.success([action])), .undo(.success(undoResult))])
+        let batcher = S221IntegrationConflictBatcher(previews: [.s221ReplacePreview()])
