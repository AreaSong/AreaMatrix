+    ) -> ImportConflictBatchApplyReportSnapshot {
+        ImportConflictBatchApplyReportSnapshot(
+            importSessionID: request.importSessionID,
+            requestedConflictCount: Int64(request.conflictIDs.count),
+            resolvedCount: Int64(request.conflictIDs.count),
