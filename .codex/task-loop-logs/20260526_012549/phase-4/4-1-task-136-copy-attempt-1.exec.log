+                    applyToAllSimilarConflicts: true,
+                    replaceConfirmed: true
+                ),
+                previewToken: "token-replace"
+            )
+        ])
+        XCTAssertEqual(listRequests, ["/tmp/repo"])
+        XCTAssertEqual(undoRequests, ["/tmp/repo|undo-import-conflict-batch"])
+    }
