        for strategy: ImportConflictBatchStrategySnapshot
    ) -> ImportConflictBatchResultStatusSnapshot {
        switch strategy {
        case .skip:
            .skipped
        case .keepBoth:
            .keptBoth
        case .replace:
            .replaced
        case .askPerItem:
            .queuedForPerItem
        }
    }
