        requests.append(Task27ChangeLogRequest(repoPath: repoPath, filter: filter))
        guard !results.isEmpty else { return [] }
        switch results.removeFirst() {
        case let .success(entries):
            return entries
        case let .failure(error):
            throw error
        }
