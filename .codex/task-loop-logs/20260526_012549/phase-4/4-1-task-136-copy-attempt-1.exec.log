+            canApply: false,
+            applyBlockedReason: "Blocked: Trash unavailable",
+            replaceConfirmationRequired: true,
+            replaceConfirmationSummary: "Replace 1 existing file?",
+            items: [.s221Item(conflictID: "dup-blocked", strategy: .replace, status: .blocked)]
+        )
