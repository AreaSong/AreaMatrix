        ["cargo", "fmt", "--all", "--", "--check"],
        ["cargo", "clippy", "--all-targets", "--all-features", "--", "-D", "warnings"],
        ["cargo", "test", "--workspace"],
    ]:
        proc = run_step(argv, cwd=core_dir, check=False)
        if proc.returncode != 0:
            return proc.returncode
    return 0


