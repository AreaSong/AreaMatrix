+        XCTAssertEqual(model.conflictBatchApplyDisabledReason, "Refresh conflict strategy preview.")
+        XCTAssertNil(await model.applyImportConflictBatch(replaceConfirmed: false))
+        XCTAssertEqual(await batcher.applyRequests(), [])
+
+        let applied = await model.applyImportConflictBatch(replaceConfirmed: true)
+        await model.undoImportConflictBatchAction()
+
+        XCTAssertEqual(applied?.report?.replacedCount, 1)
