+        copy.items = request.conflictIDs.map { conflictID in
+            let status: ImportConflictBatchPreviewStatusSnapshot = copy.canApply ? .needsConfirmation : .blocked
+            return .s221Item(conflictID: conflictID, strategy: request.duplicateStrategy, status: status)
+        }
+        return copy
+    }
