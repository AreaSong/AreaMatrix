   281	    private func editedSessionAfterApply(
   282	        _ session: TagSuggestionEditSession,
   283	        report: TagSuggestionApplyReportSnapshot
   284	    ) -> TagSuggestionEditSession {
   285	        var next = session
   286	        next.drafts = session.drafts.map { draft in
   287	            var updated = draft
   288	            guard let result = report.itemResults.first(where: { $0.suggestionID == draft.suggestionID }) else {
   289	                return updated
   290	            }
   291	            switch result.status {
   292	            case .applied:
   293	                updated.status = .applied
   294	            case .alreadyAdded:
   295	                updated.status = .alreadyAdded(result.error ?? "Already added")
   296	            case .failed:
   297	                updated.status = .blocked(result.error ?? "A suggestion could not be applied.")
   298	            }
   299	            return updated
   300	        }
   301	        return next
   302	    }
