   253	
   254	    private static func status(
   255	        for draft: TagSuggestionEditDraft,
   256	        seenSlugs: inout Set<String>,
   257	        report: TagSuggestionReportSnapshot,
   258	        disabledReason: String?
   259	    ) -> TagSuggestionEditRowStatus {
   260	        if disabledReason != nil { return .blocked("Tag store is read-only.") }
   261	        guard let suggestion = report.suggestions.first(where: { $0.suggestionID == draft.suggestionID }) else {
   262	            return .blocked("Suggestion is no longer available.")
   263	        }
   264	        if suggestion.status == .alreadyAdded { return .alreadyAdded("Already added") }
   265	        if suggestion.status == .blocked || suggestion.disabledReason != nil {
   266	            return .blocked(suggestion.disabledReason ?? "Suggestion is blocked.")
   267	        }
   268	        guard let normalized = TagInputNormalization.normalizedValue(draft.slug) else {
   269	            return .invalid(TagInputNormalization.invalidMessage)
   270	        }
   271	        if seenSlugs.contains(normalized) { return .duplicate("Duplicate slug in selected tags.") }
   272	        seenSlugs.insert(normalized)
   273	        if report.tagSet.containsFileTag(value: normalized) { return .alreadyAdded("Already added") }
   274	        return .ready
   275	    }
