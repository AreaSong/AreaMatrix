    65	enum BatchTagUndoState: Equatable {
    66	    case idle
    67	    case loading(token: String)
    68	    case ready(UndoActionRecordSnapshot)
    69	    case disabled(UndoActionRecordSnapshot, reason: String)
    70	    case unavailable(reason: String)
    71	    case undoing(UndoActionRecordSnapshot)
    72	    case undone(UndoActionResultSnapshot)
    73	    case failed(CoreErrorMappingSnapshot, previous: UndoActionRecordSnapshot?)
    74	
    75	    var action: UndoActionRecordSnapshot? {
    76	        switch self {
    77	        case let .ready(action), let .disabled(action, _), let .undoing(action), let .failed(_, action?):
    78	            action
    79	        case .idle, .loading, .unavailable, .undone, .failed:
    80	            nil
    81	        }
    82	    }
    83	
    84	    var executableAction: UndoActionRecordSnapshot? {
    85	        guard case let .ready(action) = self else { return nil }
    86	        return action
    87	    }
    88	
    89	    var isBusy: Bool {
    90	        switch self {
    91	        case .loading, .undoing:
    92	            true
    93	        case .idle, .ready, .disabled, .unavailable, .undone, .failed:
    94	            false
    95	        }
    96	    }
    97	
    98	    var isIdle: Bool {
    99	        if case .idle = self { return true }
   100	        return false
   101	    }
   102	}
