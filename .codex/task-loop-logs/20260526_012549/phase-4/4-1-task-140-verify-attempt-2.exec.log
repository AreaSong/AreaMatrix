   135	                    values.volumeAvailableCapacity.map(Int64.init),
   136	                isExternalVolume: values.volumeIsInternal.map { !$0 }
   137	            )
   138	        } catch {
   139	            return RepositoryPathEnvironmentSnapshot(availableCapacityBytes: nil, isExternalVolume: nil)
   140	        }
   141	    }
