   165	enum BatchTagUndoAction {
   166	    static func refreshLatestToastState(
   167	        repoPath: String,
   168	        undoStore: any CoreUndoActionLogging,
   169	        errorMapper: any CoreErrorMapping
   170	    ) async -> BatchTagUndoState {
   171	        let loadResult = await loadLatestAction(
   172	            repoPath: repoPath,
   173	            undoStore: undoStore,
   174	            errorMapper: errorMapper
   175	        )
   176	        return loadResult.toastState ?? .idle
   177	    }
   178	
   179	    static func completionAfterBatchApply(
   180	        repoPath: String,
   181	        report: BatchMutationReportSnapshot?,
   182	        failure: CoreErrorMappingSnapshot?,
   183	        undoStore: any CoreUndoActionLogging,
   184	        errorMapper: any CoreErrorMapping
   185	    ) async -> BatchAddTagsSheetCompletion {
   186	        guard failure == nil, let report, report.failedCount == 0 else {
   187	            return BatchAddTagsSheetCompletion(undoState: nil, closesSheet: false)
   188	        }
   189	        guard let token = normalizedToken(report.undoToken) else {
   190	            return BatchAddTagsSheetCompletion(
   191	                undoState: .unavailable(reason: "Undo is unavailable for this result."),
   192	                closesSheet: true
   193	            )
   194	        }
   195	
   196	        let loadResult = await loadAction(
   197	            repoPath: repoPath,
   198	            undoToken: token,
   199	            undoStore: undoStore,
   200	            errorMapper: errorMapper
   201	        )
   202	        if let toastState = loadResult.toastState {
   203	            return BatchAddTagsSheetCompletion(undoState: toastState, closesSheet: true)
   204	        }
   205	        return BatchAddTagsSheetCompletion(
   206	            undoState: .unavailable(reason: "Undo action is no longer available."),
   207	            closesSheet: true
   208	        )
   209	    }
   210	
   211	    static func loadAction(
   212	        repoPath: String,
   213	        undoToken: String?,
   214	        undoStore: any CoreUndoActionLogging,
   215	        errorMapper: any CoreErrorMapping
   216	    ) async -> BatchTagUndoLoadResult {
   217	        guard let token = normalizedToken(undoToken) else {
   218	            return BatchTagUndoLoadResult(action: nil, unavailableReason: "Undo is unavailable for this result.", failure: nil)
   219	        }
   220	        do {
   221	            let actions = try await undoStore.listUndoActions(repoPath: repoPath)
   222	            guard let action = actions.first(where: { $0.actionID == token }) else {
   223	                return BatchTagUndoLoadResult(action: nil, unavailableReason: "Undo action is no longer available.", failure: nil)
   224	            }
   225	            return loadResult(for: action)
   226	        } catch {
   227	            return BatchTagUndoLoadResult(
   228	                action: nil,
   229	                unavailableReason: nil,
   230	                failure: await mapError(error, errorMapper: errorMapper)
   231	            )
   232	        }
   233	    }
   234	
   235	    static func loadLatestAction(
   236	        repoPath: String,
   237	        undoStore: any CoreUndoActionLogging,
   238	        errorMapper: any CoreErrorMapping
   239	    ) async -> BatchTagUndoLoadResult {
   240	        do {
   241	            let actions = try await undoStore.listUndoActions(repoPath: repoPath)
   242	            guard let action = latestToastAction(from: actions) else {
   243	                return BatchTagUndoLoadResult(action: nil, unavailableReason: nil, failure: nil)
   244	            }
   245	            return loadResult(for: action)
   246	        } catch {
   247	            return BatchTagUndoLoadResult(
   248	                action: nil,
   249	                unavailableReason: nil,
   250	                failure: await mapError(error, errorMapper: errorMapper)
   251	            )
   252	        }
   253	    }
