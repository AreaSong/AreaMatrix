   104	struct BatchTagUndoLoadResult: Equatable {
   105	    var action: UndoActionRecordSnapshot?
   106	    var unavailableReason: String?
   107	    var failure: CoreErrorMappingSnapshot?
   108	
   109	    var toastState: BatchTagUndoState? {
   110	        if let failure { return .failed(failure, previous: action) }
   111	        if let action, let unavailableReason { return .disabled(action, reason: unavailableReason) }
   112	        if let unavailableReason { return .unavailable(reason: unavailableReason) }
   113	        if let action { return .ready(action) }
   114	        return nil
   115	    }
   116	}
