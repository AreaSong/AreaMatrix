   244	        var seenSlugs: Set<String> = []
   245	        var next = session
   246	        next.drafts = session.drafts.map { draft in
   247	            var updated = draft
   248	            updated.status = status(for: draft, seenSlugs: &seenSlugs, report: report, disabledReason: disabledReason)
   249	            return updated
   250	        }
