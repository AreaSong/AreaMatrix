   407	private actor S211RecordingUndoStore: CoreUndoActionLogging {
   408	    enum Result {
   409	        case list(Swift.Result<[UndoActionRecordSnapshot], Error>)
   410	        case undo(Swift.Result<UndoActionResultSnapshot, Error>)
   411	    }
   412	
   413	    private var results: [Result]
   414	    private var recordedListRequests: [String] = []
   415	    private var recordedUndoRequests: [String] = []
   416	
   417	    init(results: [Result]) {
   418	        self.results = results
   419	    }
   420	
   421	    func listUndoActions(repoPath: String) async throws -> [UndoActionRecordSnapshot] {
   422	        recordedListRequests.append(repoPath)
   423	        guard !results.isEmpty else { return [] }
   424	        guard case let .list(result) = results.removeFirst() else {
   425	            throw CoreError.Internal(message: "Expected listUndoActions")
   426	        }
   427	        return try result.get()
   428	    }
   429	
   430	    func undoAction(repoPath: String, actionID: String) async throws -> UndoActionResultSnapshot {
   431	        recordedUndoRequests.append("\(repoPath)|\(actionID)")
   432	        guard !results.isEmpty else {
   433	            throw CoreError.FileNotFound(path: actionID)
   434	        }
   435	        guard case let .undo(result) = results.removeFirst() else {
   436	            throw CoreError.Internal(message: "Expected undoAction")
   437	        }
   438	        return try result.get()
   439	    }
   440	
   441	    func listRequests() -> [String] {
   442	        recordedListRequests
   443	    }
   444	
   445	    func undoRequests() -> [String] {
   446	        recordedUndoRequests
   447	    }
   448	}
   449	
   450	private actor S211HistoryErrorMapper: CoreErrorMapping {
   451	    func mapCoreError(_ error: CoreError) async -> CoreErrorMappingSnapshot {
   452	        CoreErrorMappingSnapshot(
   453	            kind: kind(for: error),
   454	            userMessage: "Undo failed",
   455	            severity: .medium,
   456	            suggestedAction: "View details in Undo history.",
   457	            recoverability: .refreshRequired,
   458	            rawContext: "S2-11 C2-07 undo-action-log"
   459	        )
   460	    }
   461	
   462	    private func kind(for error: CoreError) -> CoreErrorKindSnapshot {
   463	        switch error {
   464	        case .Conflict:
   465	            .conflict
   466	        case .FileNotFound:
   467	            .fileNotFound
   468	        case .PermissionDenied:
   469	            .permissionDenied
   470	        case .Db:
   471	            .db
   472	        case .Io:
   473	            .io
   474	        default:
   475	            .internal
   476	        }
   477	    }
   478	}

