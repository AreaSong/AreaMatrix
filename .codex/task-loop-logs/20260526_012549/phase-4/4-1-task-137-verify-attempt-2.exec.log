   322	private func importProgressMirrorDescription(of value: Any) -> String {
   323	    var lines: [String] = []
   324	    appendImportProgressMirrorDescription(of: value, to: &lines)
   325	    return lines.joined(separator: "\n")
   326	}
   327	
   328	private func appendImportProgressMirrorDescription(of value: Any, to lines: inout [String]) {
   329	    lines.append(String(describing: type(of: value)))
   330	    lines.append(String(describing: value))
   331	    for child in Mirror(reflecting: value).children {
   332	        if let label = child.label {
   333	            lines.append(label)
   334	        }
   335	        appendImportProgressMirrorDescription(of: child.value, to: &lines)
   336	    }
   337	}
