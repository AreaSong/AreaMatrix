   128	struct BatchTagUndoToastHost: View {
   129	    let repoPath: String
   130	    let undoStore: any CoreUndoActionLogging
   131	    let redoStore: any CoreRedoActionLogging
   132	    let errorMapper: any CoreErrorMapping
   133	    let onRefreshSelection: () -> Void
   134	    let onRefreshChangeLog: () -> Void
   135	    let onRefreshCurrentList: () -> Void
   136	    let onOpenHistory: (UndoToastHistoryRequest) -> Void
   137	    @Binding var undoState: BatchTagUndoState
   138	    @Binding var actionLogRefreshFailure: CoreErrorMappingSnapshot?
   139	    @State private var redoState: RedoActionState = .idle
   140	
   141	    var body: some View {
   142	        Group {
   143	            if !undoState.isIdle {
   144	                BatchTagUndoToastView(
   145	                    state: undoState,
   146	                    redoState: redoState,
   147	                    actionLogRefreshFailure: actionLogRefreshFailure,
   148	                    onUndo: { action in Task { await undo(action) } },
   149	                    onRedo: { action in Task { await redo(action) } },
   150	                    onOpenHistory: openHistory,
   151	                    onDismiss: dismissUndoToast
   152	                )
   153	                .frame(maxWidth: 420)
   154	            }
   155	        }
   156	        .task(id: repoPath) { await loadLatestUndoAction() }
   157	        .onKeyPress("z", phases: .down) { event in
   158	            guard event.modifiers.contains(.command) else { return .ignored }
   159	            if event.modifiers.contains(.shift) {
   160	                if let action = redoState.executableAction, !redoState.isBusy {
   161	                    Task { await redo(action) }
   162	                    return .handled
   163	                }
   164	                return .ignored
   165	            }
   166	            if let action = undoState.executableAction, !undoState.isBusy {
   167	                Task { await undo(action) }
   168	                return .handled
   169	            }
   170	            return .ignored
   171	        }
   172	    }
   173	
   174	    @MainActor
   175	    private func loadLatestUndoAction() async {
   176	        undoState = await BatchTagUndoAction.refreshLatestToastState(
   177	            repoPath: repoPath,
   178	            undoStore: undoStore,
   179	            errorMapper: errorMapper
   180	        )
   181	    }
   182	
   183	    @MainActor
   184	    private func undo(_ action: UndoActionRecordSnapshot) async {
   185	        undoState = .undoing(action)
   186	        actionLogRefreshFailure = nil
   187	        let applied = await BatchTagUndoAction.undo(
   188	            repoPath: repoPath,
   189	            action: action,
   190	            undoStore: undoStore,
   191	            errorMapper: errorMapper
   192	        )
   193	        if let failure = applied.failure {
   194	            undoState = .failed(failure, previous: action)
   195	            return
   196	        }
   197	        guard let result = applied.result else {
   198	            undoState = .unavailable(reason: "Undo action finished without a result.")
   199	            return
   200	        }
   201	
   202	        undoState = .undone(result)
   203	        await refreshAfterUndo(result)
   204	        await loadLatestRedoAction()
   205	    }
   206	
   207	    @MainActor
   208	    private func refreshAfterUndo(_ result: UndoActionResultSnapshot) async {
   209	        let plan = BatchTagUndoRefreshPlan(refreshTargets: result.refreshTargets)
   210	        if plan.refreshesCurrentList { onRefreshCurrentList() }
   211	        if plan.refreshesSelectionDetails { onRefreshSelection() }
   212	        if plan.refreshesChangeLog { onRefreshChangeLog() }
   213	        guard plan.refreshesUndoActions else { return }
   214	
   215	        let refreshed = await BatchTagUndoAction.refreshActionLog(
   216	            repoPath: repoPath,
   217	            actionID: result.actionID,
   218	            undoStore: undoStore,
   219	            errorMapper: errorMapper
   220	        )
   221	        actionLogRefreshFailure = refreshed.failure
   222	    }
   223	
   224	    @MainActor
   225	    private func loadLatestRedoAction() async {
   226	        let previous = redoState.action
   227	        redoState = .checking(previous: previous)
   228	        let loaded = await RedoActionFeedback.loadLatestAction(
   229	            repoPath: repoPath,
   230	            redoStore: redoStore,
   231	            errorMapper: errorMapper
   232	        )
   233	        redoState = loaded.feedbackState() ?? .idle
   234	    }
   235	
   236	    @MainActor
   237	    private func redo(_ action: RedoActionRecordSnapshot) async {
   238	        redoState = .redoing(action)
   239	        let applied = await RedoActionFeedback.redo(
   240	            repoPath: repoPath,
   241	            action: action,
   242	            redoStore: redoStore,
   243	            errorMapper: errorMapper
   244	        )
   245	        if let failure = applied.failure {
   246	            redoState = .failed(failure, previous: action)
   247	            return
   248	        }
   249	        guard let result = applied.result else {
   250	            redoState = .unavailable(reason: "Redo action finished without a result.")
   251	            return
   252	        }
   253	
   254	        redoState = .redone(result)
   255	        await refreshAfterRedo(result)
   256	    }
   257	
   258	    @MainActor
   259	    private func refreshAfterRedo(_ result: RedoActionResultSnapshot) async {
   260	        let plan = BatchTagUndoRefreshPlan(refreshTargets: result.refreshTargets)
   261	        if plan.refreshesCurrentList { onRefreshCurrentList() }
   262	        if plan.refreshesSelectionDetails { onRefreshSelection() }
   263	        if plan.refreshesChangeLog { onRefreshChangeLog() }
   264	        if plan.refreshesUndoActions {
   265	            await loadLatestUndoAction()
   266	        }
   267	    }
   268	
   269	    private func dismissUndoToast() {
   270	        undoState = .idle
   271	        redoState = .idle
   272	        actionLogRefreshFailure = nil
   273	    }
   274	
   275	    private func openHistory(_ source: UndoToastHistoryRequest.Source) {
   276	        onOpenHistory(UndoToastHistoryRequest(
   277	            source: source,
   278	            state: undoState,
   279	            actionLogRefreshFailure: actionLogRefreshFailure
   280	        ))
   281	    }
   282	}
