--- /dev/null
+++ b/apps/macos/AreaMatrixTests/S222RedoUndoSourcePageFeatureTests.swift
@@ -0,0 +1,64 @@
+@testable import AreaMatrix
+import XCTest
+
+final class S222RedoUndoSourcePageFeatureTests: XCTestCase {
+    func testS222C207RedoSourceUsesLoadedUndoActionLogSummary() {
+        let undo = UndoActionRecordSnapshot.s222SourceUndo()
+        let redo = RedoActionRecordSnapshot.s222AvailableRedo()
+        let presentation = RedoUndoSourcePresentation(redoAction: redo, undoActions: [undo])
+
+        XCTAssertEqual(presentation.sourceText, "Source undo: Undone: moved 3 files back.")
+        XCTAssertEqual(presentation.statusText, "Available until the next file operation")
+        XCTAssertTrue(presentation.accessibilityText.contains("Source undo: Undone: moved 3 files back."))
+    }
+
+    func testS222C207RedoSourceFallsBackToStableSourceUndoIDWhenActionLogIsMissing() {
+        let redo = RedoActionRecordSnapshot.s222AvailableRedo()
+        let presentation = RedoUndoSourcePresentation(redoAction: redo, undoActions: [])
+
+        XCTAssertEqual(presentation.sourceText, "Source undo undo-trash-3")
+    }
+
+    func testS222C207UndoHistorySnapshotFindsSourceUndoActionForRedoRow() {
+        let undo = UndoActionRecordSnapshot.s222SourceUndo()
+        let redo = RedoActionRecordSnapshot.s222AvailableRedo()
+        let snapshot = UndoHistorySnapshot(undoActions: [undo], redoActions: [redo])
+
+        XCTAssertEqual(snapshot.sourceUndoAction(for: redo), undo)
+    }
+}
+
+private extension UndoActionRecordSnapshot {
+    static func s222SourceUndo() -> UndoActionRecordSnapshot {
+        UndoActionRecordSnapshot(
+            actionID: "undo-trash-3",
+            kind: "trash_delete",
+            summary: "Undone: moved 3 files back.",
+            affectedCount: 3,
+            affectedFileNames: ["a.pdf", "b.pdf", "c.pdf"],
+            status: .executed,
+            canUndo: false,
+            disabledReason: "This action has already been undone.",
+            createdAt: 1_700_000_000,
+            updatedAt: 1_700_000_040
+        )
+    }
+}
+
+private extension RedoActionRecordSnapshot {
+    static func s222AvailableRedo() -> RedoActionRecordSnapshot {
+        RedoActionRecordSnapshot(
+            actionID: "redo-move-3",
+            kind: "move_files",
+            summary: "Redo: Move 3 files to Documents",
+            affectedCount: 3,
+            affectedFileNames: ["a.pdf", "b.pdf", "c.pdf"],
+            status: .available,
+            canRedo: true,
+            disabledReason: nil,
+            sourceUndoActionID: "undo-trash-3",
+            createdAt: 1_700_000_045,
+            updatedAt: 1_700_000_045
+        )
+    }
+}

