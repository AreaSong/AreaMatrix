+                    conflictType: .duplicateHash,
+                    appliedStrategy: request.duplicateStrategy,
+                    status: .replaced,
+                    fileID: 42,
+                    finalPath: "finance/Invoice_2026Q1.pdf",
+                    error: nil
+                )
+            },
+            affectedFileIDs: [42],
+            undoToken: "undo-import-conflict-batch",
+            changeLogActions: ["import_conflict_batch"],
