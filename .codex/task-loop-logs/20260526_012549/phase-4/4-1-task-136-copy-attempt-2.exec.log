+    undoStore: any CoreUndoActionLogging
+) -> ImportBatchCopyImportModel {
+    ImportBatchCopyImportModel(
+        importer: S118RecordingBatchImporter(),
+        errorMapper: S117RecordingErrorMapper(),
+        conflictBatcher: conflictBatcher,
+        undoActionStore: undoStore
+    )
+}
