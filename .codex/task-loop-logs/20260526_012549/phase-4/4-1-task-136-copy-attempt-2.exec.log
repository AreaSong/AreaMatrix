+            request: s221IntegrationRequest(urls: [invoiceURL], conflictIDs: ["dup-1"]),
+            selectedDestination: .autoClassify
+        )
+        model.updateConflictBatchDuplicateStrategy(.replace)
+        await model.loadImportConflictBatchPreview()
