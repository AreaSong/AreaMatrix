+        return false
+    }
+
+    var failure: CoreErrorMappingSnapshot? {
+        guard case let .failed(_, mapping, _) = self else { return nil }
+        return mapping
+    }
+
+    var appliedReport: TagSuggestionApplyReportSnapshot? {
+        guard case let .applied(_, _, report, _) = self else { return nil }
+        return report
+    }
+
+    var fileID: Int64? {
+        switch self {
+        case let .loading(fileID, _), let .loaded(fileID, _, _), let .applying(fileID, _, _),
+             let .applied(fileID, _, _, _), let .failed(fileID, _, _):
+            fileID
+        case .idle:
+            nil
+        }
+    }
+}
