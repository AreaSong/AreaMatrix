  1773	### `predict_category(repoPath: String, filename: String) throws -> ClassifyResult`
  1774	
  1775	```swift
  1776	let result = try AreaMatrix.predictCategory(
  1777	    repoPath: repoPath,
  1778	    filename: "Invoice_2026Q1.pdf"
  1779	)
  1780	// result.category == "finance"
  1781	// result.reason == .keyword
  1782	// result.confidence == 0.9
  1783	
  1784	importSheet.suggestedCategory = result.category
  1785	importSheet.confidence = result.confidence
