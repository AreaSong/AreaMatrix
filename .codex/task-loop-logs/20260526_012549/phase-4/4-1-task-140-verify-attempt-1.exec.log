  3947	
  3948	## CoreBridge 包装层（推荐做法）
  3949	
  3950	UI 不直接调 `AreaMatrix.*`，而是通过应用层 `CoreBridge` actor 包装：
  3951	
  3952	```swift
  3953	public actor CoreBridge {
  3954	    private let repoPath: String
  3955	    private let queue: TaskGroup<Void>?
  3956	
  3957	    public init(repoPath: String) {
  3958	        self.repoPath = repoPath
  3959	    }
  3960	
  3961	    public func bootstrap() async throws -> RecoveryReport {
  3962	        try AreaMatrix.initLogging(level: "info")
  3963	        return try AreaMatrix.recoverOnStartup(repoPath: repoPath)
  3964	    }
  3965	
  3966	    public func importFile(from src: URL, options: ImportOptions) async throws -> FileEntry {
  3967	        try await Task.detached(priority: .userInitiated) { [repoPath] in
  3968	            try AreaMatrix.importFile(
  3969	                repoPath: repoPath,
  3970	                sourcePath: src.path,
  3971	                options: options
  3972	            )
  3973	        }.value
  3974	    }
  3975	
  3976	    public func listFiles(filter: FileFilter) async throws -> [FileEntry] {
  3977	        try await Task.detached(priority: .userInitiated) { [repoPath] in
  3978	            try AreaMatrix.listFiles(repoPath: repoPath, filter: filter)
  3979	        }.value
  3980	    }
  3981	
  3982	    public func tree(locale: String) async throws -> TreeNode {
  3983	        let json = try await Task.detached(priority: .userInitiated) { [repoPath] in
  3984	            try AreaMatrix.listTreeJson(repoPath: repoPath, locale: locale)
  3985	        }.value
  3986	        let decoder = JSONDecoder()
  3987	        decoder.keyDecodingStrategy = .convertFromSnakeCase
  3988	        return try decoder.decode(TreeNode.self, from: json.data(using: .utf8)!)
  3989	    }
  3990	}
  3991	```
  3992	
  3993	详见 [../architecture/ffi-design.md](../architecture/ffi-design.md) 与 [uniffi-recipes.md](uniffi-recipes.md)。
  3994	
