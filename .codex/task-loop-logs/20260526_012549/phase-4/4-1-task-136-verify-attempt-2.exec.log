   147	struct ImportConflictBatchUndoStateView: View {
   148	    let state: BatchTagUndoState
   149	    let onUndo: () -> Void
   150	    let onDismiss: () -> Void
   151	
   152	    var body: some View {
   153	        switch state {
   154	        case .idle:
   155	            EmptyView()
   156	        case let .loading(token):
   157	            undoStatus("Loading Undo action \(token)...")
   158	        case let .ready(action):
   159	            HStack(spacing: 8) {
   160	                undoStatus(action.summary)
   161	                Button("Undo", action: onUndo)
   162	                    .keyboardShortcut("z", modifiers: [.command])
   163	            }
   164	            .accessibilityLabel("Undo available. \(action.summary)")
   165	        case let .disabled(action, reason):
   166	            undoStatus("\(action.summary) \(reason)")
   167	        case let .unavailable(reason):
   168	            undoStatus(reason)
   169	        case let .undoing(action):
   170	            HStack(spacing: 8) {
   171	                ProgressView()
   172	                    .controlSize(.small)
   173	                undoStatus("Undoing \(action.summary)")
   174	            }
   175	        case let .undone(result):
   176	            HStack(spacing: 8) {
   177	                undoStatus(result.summary)
   178	                Button("Dismiss", action: onDismiss)
   179	            }
   180	            .accessibilityLabel("Undo completed. \(result.summary)")
   181	        case let .failed(mapping, previous):
   182	            HStack(spacing: 8) {
   183	                undoStatus(mapping.userMessage)
   184	                    .foregroundStyle(.red)
   185	                if previous != nil {
   186	                    Button("Dismiss", action: onDismiss)
   187	                }
   188	            }
   189	            .accessibilityLabel("Undo failed. \(mapping.userMessage)")
   190	        }
   191	    }
   192	
   193	    private func undoStatus(_ text: String) -> some View {
   194	        Text(text)
   195	            .font(.caption)
   196	            .foregroundStyle(.secondary)
   197	    }
   198	}

