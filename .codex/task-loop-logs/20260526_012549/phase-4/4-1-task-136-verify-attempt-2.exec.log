   300	    func load(request: ImportEntryRequest) async {
   301	        generation += 1
   302	        let currentGeneration = generation
   303	        self.request = request
   304	
   305	        if let route = request.importConflictBatchRoute {
   306	            loadImportConflictBatchRoute(request: request, route: route)
