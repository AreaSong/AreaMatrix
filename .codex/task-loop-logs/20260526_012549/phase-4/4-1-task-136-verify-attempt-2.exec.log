   354	    private func loadImportConflictBatchRoute(
   355	        request: ImportEntryRequest,
   356	        route: ImportConflictBatchRoute
   357	    ) {
   358	        selectedDestination = request.initialBatchDestination
   359	        let rowStatus = ImportBatchPreviewRowStatus.nameConflict(
   360	            existingPath: "Core import session \(route.importSessionID)",
   361	            reasonLabel: "Waiting for Core conflict batch preview"
   362	        )
   363	        rows = route.conflictIDs.map {
   364	            ImportBatchPreviewRow(
   365	                originalName: $0, sourcePath: $0, sizeBytes: nil, predictedCategory: nil,
   366	                suggestedName: $0, status: rowStatus
   367	            )
   368	        }
   369	        status = .loaded(successful: rows.count, total: rows.count, failed: 0)
   370	    }
