   308	        }
   309	
   310	        guard case .multipleItems = request.kind, request.urls.count > 1 else {
   311	            rows = []
   312	            status = .unsupported("此 sheet 只处理批量文件导入")
   313	            return
   314	        }
   315	
   316	        selectedDestination = request.initialBatchDestination
   317	        rows = request.urls.map(ImportBatchPreviewRow.loading)
   318	        status = .loading(completed: 0, total: request.urls.count)
   319	        await Task.yield()
   320	        let duplicatePrecheck = await duplicatePrechecker?.precheckDuplicates(
   321	            repoPath: request.repoPath,
   322	            sourceURLs: request.urls,
   323	            destination: selectedDestination
   324	        ) ?? [:]
   325	
   326	        var completed = 0
   327	        var pendingRows = rows
   328	        for (index, url) in request.urls.enumerated() {
   329	            pendingRows[index] = await previewRow(
   330	                url: url,
   331	                request: request,
   332	                duplicatePrecheck: duplicatePrecheck[url.path]
   333	            )
   334	            guard generation == currentGeneration else { return }
   335	            completed += 1
   336	            if shouldPublishPreviewProgress(completed: completed, total: request.urls.count) {
   337	                rows = pendingRows
   338	                status = .loading(completed: completed, total: request.urls.count)
   339	                await Task.yield()
   340	            }
   341	        }
   342	
   343	        rows = pendingRows
   344	        status = .loading(completed: completed, total: request.urls.count)
   345	        await applyNameConflictPrecheck(repoPath: request.repoPath, generation: currentGeneration)
   346	        guard generation == currentGeneration else { return }
   347	        status = .loaded(
   348	            successful: successfulPreviewCount,
   349	            total: rows.count,
   350	            failed: failedPreviewCount
   351	        )
   352	    }
