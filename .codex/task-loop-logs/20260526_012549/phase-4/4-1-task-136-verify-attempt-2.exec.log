   305	enum ImportConflictBatchUndoAction {
   306	    static func stateAfterBatchApply(
   307	        repoPath: String,
   308	        report: ImportConflictBatchApplyReportSnapshot?,
   309	        failure: CoreErrorMappingSnapshot?,
   310	        undoStore: any CoreUndoActionLogging,
   311	        errorMapper: any CoreErrorMapping
   312	    ) async -> BatchTagUndoState? {
   313	        guard failure == nil, let report, report.shouldRefreshUndoActionLogAfterApply else { return nil }
   314	        guard let token = normalizedToken(report.undoToken) else {
   315	            return .unavailable(reason: "Undo is unavailable for this import conflict result.")
   316	        }
   317	
   318	        let loadResult = await BatchTagUndoAction.loadAction(
   319	            repoPath: repoPath,
   320	            undoToken: token,
   321	            undoStore: undoStore,
   322	            errorMapper: errorMapper
   323	        )
   324	        return loadResult.toastState ?? .unavailable(reason: "Undo action is no longer available.")
   325	    }
   326	
   327	    static func undo(
   328	        repoPath: String,
   329	        state: BatchTagUndoState,
   330	        undoStore: any CoreUndoActionLogging,
   331	        errorMapper: any CoreErrorMapping
   332	    ) async -> BatchTagUndoState {
   333	        guard let action = state.executableAction else { return state }
   334	        let result = await BatchTagUndoAction.undo(
   335	            repoPath: repoPath,
   336	            action: action,
   337	            undoStore: undoStore,
   338	            errorMapper: errorMapper
   339	        )
   340	        if let undoResult = result.result {
   341	            return .undone(undoResult)
   342	        }
   343	        if let failure = result.failure {
   344	            return .failed(failure, previous: action)
   345	        }
   346	        return .failed(await fallbackMapping(errorMapper: errorMapper), previous: action)
   347	    }
   348	
   349	    private static func normalizedToken(_ undoToken: String?) -> String? {
   350	        let token = undoToken?.trimmingCharacters(in: .whitespacesAndNewlines) ?? ""
   351	        return token.isEmpty ? nil : token
   352	    }
   353	
   354	    private static func fallbackMapping(errorMapper: any CoreErrorMapping) async -> CoreErrorMappingSnapshot {
   355	        await errorMapper.mapCoreError(CoreError.Internal(message: "undo_action returned no result"))
   356	    }
   357	}
