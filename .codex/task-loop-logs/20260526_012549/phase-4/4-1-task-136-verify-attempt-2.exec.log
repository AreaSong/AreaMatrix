   333	    func applyImportConflictBatch(replaceConfirmed: Bool? = nil) async -> ImportConflictBatchApplyResult? {
   334	        guard let preview = conflictBatchPreviewReport,
   335	              let request = makeImportConflictBatchApplyRequest(
   336	                  replaceConfirmed: replaceConfirmed ?? isConflictBatchReplaceConfirmed
   337	              ) else { return nil }
   338	        guard ImportConflictBatchValidation.canApply(
   339	            preview: preview,
   340	            request: request,
   341	            isApplying: isConflictBatchApplying
   342	        ) else { return nil }
   343	        isConflictBatchApplying = true
   344	        defer { isConflictBatchApplying = false }
   345	        let result = await ImportConflictBatchAction.apply(
   346	            repoPath: self.request?.repoPath ?? "",
   347	            request: request,
   348	            preview: preview,
   349	            batcher: conflictBatcher,
   350	            errorMapper: errorMapper
   351	        )
   352	        conflictBatchApplyResult = result
   353	        if let report = result.report {
   354	            applyImportConflictBatchReportToRows(report)
   355	            await refreshConflictBatchUndoState(report: report, failure: result.failure)
   356	        } else {
   357	            conflictBatchUndoState = .idle
   358	        }
   359	        return result
   360	    }
