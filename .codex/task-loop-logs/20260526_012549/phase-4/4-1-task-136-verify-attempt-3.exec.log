   389	    ) -> Bool {
   390	        guard decision.understandsReplace else {
   391	            recordReplaceConfirmationFailure("Replace 需要先勾选二次确认")
   392	            return false
   393	        }
   394	        guard let expected = currentReplaceConfirmationContext(for: rowID), expected == decision.context else {
   395	            recordReplaceConfirmationFailure("Replace confirmation context expired")
   396	            return false
   397	        }
   398	        guard let row = rows.first(where: { $0.id == rowID }) else { return false }
   399	
   400	        switch row.status {
   401	        case let .duplicate(existingPath, .replace, _):
   402	            setStatus(.duplicate(
   403	                existingPath: existingPath,
   404	                strategy: .replace,
   405	                isReplaceConfirmed: true
   406	            ), for: rowID)
   407	        case let .nameConflict(existingPath, .replace):
   408	            setStatus(.nameConflict(
   409	                existingPath: existingPath,
   410	                resolution: .replace(isConfirmed: true)
