   404	        let undoCount = state.actions.filter { $0.status == .pending && $0.canUndo }.count
   405	        let redoCount = state.snapshot.redoActions.filter { $0.status == .available && $0.canRedo }.count
   406	        if redoCount > 0 { return "\(redoCount) action can be redone" }
   407	        return undoCount == 0 ? "No undoable actions" : "\(undoCount) actions can be undone"
