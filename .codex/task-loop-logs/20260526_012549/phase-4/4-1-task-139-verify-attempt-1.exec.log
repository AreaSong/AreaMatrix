   142	    @MainActor
   143	    func executeLatestRedoAction(entryPoint: RedoLatestEntryPoint) async {
   144	        if entryPoint == .commandPalette {
   145	            fileListModel.commandPaletteState = .loading(commandPaletteContext())
   146	        }
   147	        let loaded = await UndoHistoryActionLog.load(
   148	            repoPath: opening.config.repoPath,
   149	            undoStore: fileListModel.undoActionStore,
   150	            redoStore: fileListModel.redoActionStore,
   151	            errorMapper: fileListModel.errorMapper
   152	        )
   153	        guard case let .loaded(snapshot) = loaded else {
   154	            handleRedoEntryFailure(loaded.failure, entryPoint: entryPoint)
   155	            return
   156	        }
   157	        let result = await UndoHistoryActionLog.redoLatest(
   158	            repoPath: opening.config.repoPath,
   159	            snapshot: snapshot,
   160	            undoStore: fileListModel.undoActionStore,
   161	            redoStore: fileListModel.redoActionStore,
   162	            errorMapper: fileListModel.errorMapper
   163	        )
   164	        handleRedoEntryResult(result, entryPoint: entryPoint)
   165	    }
   166	
   167	    @MainActor
   168	    private func handleRedoEntryResult(_ state: UndoHistoryState, entryPoint: RedoLatestEntryPoint) {
   169	        switch state {
   170	        case let .redone(result, _):
   171	            closeCommandPaletteIfNeeded(entryPoint)
   172	            handleRedoHistoryResult(result)
   173	        case let .redoFailed(mapping, _, _), let .refreshFailed(mapping, _):
   174	            handleRedoEntryFailure(mapping, entryPoint: entryPoint)
   175	        case .loaded:
   176	            handleRedoEntryFailure(RedoLatestEntryPoint.noRedoMapping, entryPoint: entryPoint)
   177	        case let .failed(mapping):
   178	            handleRedoEntryFailure(mapping, entryPoint: entryPoint)
   179	        case .loading, .undoing, .undoFailed, .undone, .redoing:
   180	            break
   181	        }
   182	    }
