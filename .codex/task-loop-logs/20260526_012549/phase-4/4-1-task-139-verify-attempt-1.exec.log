   428	    @MainActor
   429	    private func undoLatest() async {
   430	        let previous = state.snapshot
   431	        guard let latest = previous.undoActions.first else { return }
   432	        state = .undoing(latest, previous: previous)
   433	        state = await UndoHistoryActionLog.undoLatest(
   434	            repoPath: repoPath,
   435	            snapshot: previous,
   436	            undoStore: undoStore,
   437	            redoStore: redoStore,
   438	            errorMapper: errorMapper
   439	        )
   440	        selectedActionID = UndoHistoryActionLog.action(in: state.actions, focusedActionID: latest.actionID)?.actionID
   441	        if case let .undone(result, _) = state {
   442	            onUndoCompleted(result)
   443	        }
   444	    }
   445	
   446	    @MainActor
   447	    private func redoLatest() async {
   448	        let previous = state.snapshot
   449	        guard let latest = previous.redoActions.first else { return }
   450	        state = .redoing(latest, previous: previous)
   451	        state = await UndoHistoryActionLog.redoLatest(
   452	            repoPath: repoPath,
   453	            snapshot: previous,
   454	            undoStore: undoStore,
   455	            redoStore: redoStore,
   456	            errorMapper: errorMapper
   457	        )
   458	        selectedActionID = UndoHistoryActionLog.action(in: state.actions, focusedActionID: selectedActionID)?.actionID
   459	        if case let .redone(result, _) = state {
   460	            onRedoCompleted(result)
   461	        }
   462	    }
   463	}
