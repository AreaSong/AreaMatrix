<UserControl
    x:Class="AreaMatrix.Features.Recovery.MissingFileRecoveryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        Padding="20"
        Spacing="12"
        Width="520"
        AutomationProperties.Name="S4-X-06 C4-18 missing file recovery">
        <TextBlock
            Text="File is missing"
            Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock
            Text="{Binding SummaryText}"
            TextWrapping="Wrap"
            AutomationProperties.LiveSetting="Polite" />

        <Grid ColumnSpacing="12" RowSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="File" />
            <TextBlock
                Grid.Column="1"
                Text="{Binding State.FileText}"
                TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Text="Last known location" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                Text="{Binding State.LastKnownLocationText}"
                TextWrapping="Wrap" />
            <TextBlock Grid.Row="2" Text="Last seen" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="1"
                Text="{Binding State.LastSeenText}" />
            <TextBlock Grid.Row="3" Text="Reason" />
            <TextBlock
                Grid.Row="3"
                Grid.Column="1"
                Text="{Binding State.ReasonText}" />
        </Grid>

        <TextBox
            x:Name="SelectedRelinkPathTextBox"
            Header="Selected file path"
            Text="{Binding SelectedRelinkPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="RelinkButton"
                Content="Relink File"
                IsEnabled="{Binding CanRelink}"
                Click="RelinkButton_Click" />
            <Button
                x:Name="TryAgainButton"
                Content="Try Again"
                IsEnabled="{Binding CanTryAgain}"
                Click="TryAgainButton_Click" />
            <Button
                x:Name="DecideLaterButton"
                Content="Decide Later"
                Click="DecideLaterButton_Click" />
        </StackPanel>

        <Border
            BorderBrush="{ThemeResource SystemControlErrorTextForegroundBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12">
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Remove this record?"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="This removes the AreaMatrix record only. It will not delete any user file from disk."
                    TextWrapping="Wrap" />
                <CheckBox
                    x:Name="RemoveRecordConfirmCheckBox"
                    Content="I understand this only removes the record."
                    IsChecked="{Binding RemoveRecordConfirmed, Mode=TwoWay}" />
                <Button
                    x:Name="RemoveRecordButton"
                    Content="Remove Record"
                    IsEnabled="{Binding CanRemoveRecord}"
                    Click="RemoveRecordButton_Click" />
            </StackPanel>
        </Border>

        <TextBlock
            Text="{Binding ResultText}"
            TextWrapping="Wrap"
            AutomationProperties.LiveSetting="Polite" />
    </StackPanel>
</UserControl>
