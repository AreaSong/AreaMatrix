<UserControl
    x:Class="AreaMatrix.Features.Settings.RepositorySettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="Repository Settings"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                x:Name="RepositorySummaryTextBlock"
                TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="12">
                <InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="True"
                    Severity="Informational" />
                <TextBlock
                    x:Name="NameTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="LocationTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="TypeTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="LastOpenedTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="CoreVersionTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="AccessTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="WatcherTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="CloudTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="LocaleTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    Text="Repository config"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <CheckBox
                    x:Name="FallbackToInboxCheckBox"
                    Content="Fallback uncategorized files to Inbox"
                    Click="FallbackToInboxCheckBox_Click" />
                <TextBlock
                    x:Name="SaveFailureTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="DiagnosticsStatusTextBlock"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="ReconnectRepositoryButton"
                Content="Reconnect Repository"
                Click="ReconnectRepositoryButton_Click" />
            <Button
                x:Name="ChooseAnotherFolderButton"
                Content="Choose Another Folder"
                Click="ChooseAnotherFolderButton_Click" />
            <Button
                x:Name="PlatformCapabilitiesButton"
                Content="Platform capabilities"
                Click="PlatformCapabilitiesButton_Click" />
            <Button
                x:Name="ExportDiagnosticsButton"
                Content="Export diagnostics"
                Click="ExportDiagnosticsButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
