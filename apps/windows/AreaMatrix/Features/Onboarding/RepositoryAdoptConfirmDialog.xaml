<UserControl
    x:Class="AreaMatrix.Features.Onboarding.RepositoryAdoptConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        Padding="40"
        RowSpacing="20"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="Use Existing Folder"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                x:Name="StatusTextBlock"
                AutomationProperties.LiveSetting="Polite"
                TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16">
                <Border
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Name="SafetyTextBlock"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="MetadataAddTextBlock"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="RollbackTextBlock"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Folder"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        x:Name="FolderTextBlock"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                    <TextBlock
                        x:Name="EstimatedItemsTextBlock"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="WritableTextBlock"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="MetadataTextBlock"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="LocationTypeTextBlock"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="RiskTextBlock"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Expander Header="What will be added?">
                    <TextBlock
                        x:Name="AddedDetailsTextBlock"
                        TextWrapping="Wrap" />
                </Expander>

                <StackPanel Spacing="8">
                    <CheckBox
                        x:Name="MetadataAcknowledgementCheckBox"
                        Content="I understand AreaMatrix will add metadata to this folder."
                        Checked="AcknowledgementCheckBox_Changed"
                        Unchecked="AcknowledgementCheckBox_Changed" />
                    <CheckBox
                        x:Name="SyncRiskAcknowledgementCheckBox"
                        Content="I understand this location may sync or report changes differently."
                        Checked="AcknowledgementCheckBox_Changed"
                        Unchecked="AcknowledgementCheckBox_Changed" />
                </StackPanel>

                <StackPanel
                    x:Name="FailureSection"
                    Spacing="8"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="ErrorTextBlock"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="TryAgainButton"
                        Content="Try Again"
                        Click="TryAgainButton_Click" />
                </StackPanel>

                <TextBlock
                    x:Name="DisabledReasonTextBlock"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                x:Name="RepositoryAdoptProgressRing"
                Width="20"
                Height="20"
                IsIndeterminate="True"
                HorizontalAlignment="Left" />

            <Button
                Grid.Column="1"
                Content="Cancel"
                Click="CancelButton_Click" />
            <Button
                Grid.Column="2"
                Content="Choose Another Folder"
                Click="ChooseAnotherFolderButton_Click" />
            <Button
                x:Name="UseThisFolderButton"
                Grid.Column="3"
                Content="Use This Folder"
                Style="{ThemeResource AccentButtonStyle}"
                Click="UseThisFolderButton_Click" />
        </Grid>
    </Grid>
</UserControl>
