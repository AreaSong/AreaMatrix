<Page
    x:Class="AreaMatrix.Features.Onboarding.ChooseRepositoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="Choose AreaMatrix Repository"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Select a folder that contains your AreaMatrix repository, or choose an empty folder to create one."
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBox
                x:Name="RepositoryFolderTextBox"
                Header="Repository folder"
                PlaceholderText="C:\Users\you\Documents\AreaMatrix"
                AutomationProperties.Name="Repository folder"
                LostFocus="RepositoryFolderTextBox_LostFocus"
                KeyDown="RepositoryFolderTextBox_KeyDown"
                TextChanged="RepositoryFolderTextBox_TextChanged" />

            <TextBlock
                x:Name="StatusTextBlock"
                AutomationProperties.LiveSetting="Polite"
                TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                x:Name="CheckingProgressRing"
                Width="20"
                Height="20"
                IsIndeterminate="True"
                HorizontalAlignment="Left" />

            <Button
                Grid.Column="1"
                Content="Cancel"
                Click="CancelButton_Click" />
            <Button
                Grid.Column="2"
                Content="Browse..."
                Click="BrowseButton_Click" />
            <Button
                x:Name="ContinueButton"
                Grid.Column="3"
                Content="Continue"
                Style="{ThemeResource AccentButtonStyle}"
                Click="ContinueButton_Click" />
        </Grid>
    </Grid>
</Page>
