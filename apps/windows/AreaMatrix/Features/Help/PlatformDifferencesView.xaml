<UserControl
    x:Class="AreaMatrix.Features.Help.PlatformDifferencesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="Platform capabilities"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                x:Name="PlatformSummaryTextBlock"
                TextWrapping="Wrap" />
            <TextBlock
                Text="Read-only capability and binding contract checks. No repository files are opened or modified."
                TextWrapping="Wrap" />
            <TextBlock
                Text="The capability matrix does not replace operation-time permission checks."
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="CheckCapabilitiesButton"
                    Content="Check capabilities"
                    Click="CheckCapabilitiesButton_Click" />
                <ProgressRing
                    x:Name="CapabilitiesProgressRing"
                    Grid.Column="1"
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Left"
                    IsIndeterminate="True" />
            </Grid>

            <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="BindingTargetComboBox"
                Header="Binding target"
                SelectionChanged="BindingTargetComboBox_SelectionChanged" />
            <Button
                x:Name="CheckContractButton"
                Grid.Column="1"
                Content="Check contract"
                Click="CheckContractButton_Click" />
            <ProgressRing
                x:Name="ContractProgressRing"
                Grid.Column="2"
                Width="20"
                Height="20"
                HorizontalAlignment="Left"
                IsIndeterminate="True" />
            </Grid>
        </StackPanel>

        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="12">
                <InfoBar
                    x:Name="CapabilitiesStatusInfoBar"
                    IsOpen="True"
                    Severity="Informational" />
                <TextBlock
                    x:Name="CapabilitiesSummaryTextBlock"
                    TextWrapping="Wrap" />
                <ItemsControl x:Name="CapabilityRowsItemsControl" />
                <InfoBar
                    x:Name="ContractStatusInfoBar"
                    IsOpen="True"
                    Severity="Informational" />
                <TextBlock
                    x:Name="ContractSummaryTextBlock"
                    TextWrapping="Wrap" />
                <TextBlock
                    Text="Supported APIs"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <ItemsControl x:Name="SupportedApisItemsControl" />
                <TextBlock
                    Text="Type mappings"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <ItemsControl x:Name="TypeMappingsItemsControl" />
                <TextBlock
                    Text="Limited or missing capabilities"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <ItemsControl x:Name="MissingCapabilitiesItemsControl" />
            </StackPanel>
        </ScrollViewer>

        <Button
            x:Name="ClosePlatformDifferencesButton"
            Grid.Row="3"
            HorizontalAlignment="Right"
            Content="Close"
            Click="ClosePlatformDifferencesButton_Click" />
    </Grid>
</UserControl>
