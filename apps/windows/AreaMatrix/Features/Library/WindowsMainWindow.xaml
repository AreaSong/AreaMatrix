<UserControl
    x:Class="AreaMatrix.Features.Library.WindowsMainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:library="using:AreaMatrix.Features.Library"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar DefaultLabelPosition="Right">
            <AppBarButton
                x:Name="RefreshButton"
                Icon="Refresh"
                Label="Refresh"
                Click="RefreshButton_Click" />
            <CommandBar.Content>
                <Grid MinWidth="360" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="SearchTextBox"
                        PlaceholderText="Search"
                        KeyDown="SearchTextBox_KeyDown" />
                    <Button
                        Grid.Column="1"
                        Content="Search"
                        Click="SearchButton_Click" />
                </Grid>
            </CommandBar.Content>
        </CommandBar>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.Row="1"
            IsOpen="False"
            Severity="Informational" />

        <Grid Grid.Row="2" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="180" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="320" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Grid Padding="16" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="RepoNameTextBlock"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        x:Name="RepoPathTextBlock"
                        TextTrimming="CharacterEllipsis"
                        ToolTipService.ToolTip="{Binding RepoPath}" />
                </StackPanel>
                <ListView
                    x:Name="CategoryListView"
                    Grid.Row="1"
                    AutomationProperties.Name="Repository navigation"
                    SelectionChanged="CategoryListView_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="library:DesktopCategoryNode">
                            <Grid Padding="0,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{x:Bind DisplayName}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind CountText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" Padding="16" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        x:Name="FileListTitleTextBlock"
                        Text="Files"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <ProgressRing
                        x:Name="LoadingProgressRing"
                        Width="18"
                        Height="18"
                        IsIndeterminate="True"
                        Visibility="Collapsed" />
                </StackPanel>
                <ListView
                    x:Name="FileListView"
                    Grid.Row="1"
                    AutomationProperties.Name="Repository files"
                    SelectionChanged="FileListView_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="library:DesktopFileEntry">
                            <Grid Padding="0,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" MinWidth="160" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock
                                        Text="{x:Bind DisplayName}"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{x:Bind Path}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Category}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind SizeText}" />
                                <TextBlock
                                    Grid.Column="3"
                                    Text="{x:Bind StatusText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="2" Padding="16" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    x:Name="DetailTitleTextBlock"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="DetailPathTextBlock"
                    Grid.Row="1"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="DetailStatusTextBlock"
                    Grid.Row="2" />
                <TabView Grid.Row="3">
                    <TabViewItem Header="Meta">
                        <StackPanel Padding="0,12" Spacing="6">
                            <TextBlock x:Name="DetailCategoryTextBlock" />
                            <TextBlock x:Name="DetailSizeTextBlock" />
                            <TextBlock x:Name="DetailUpdatedTextBlock" />
                        </StackPanel>
                    </TabViewItem>
                    <TabViewItem Header="Log" IsEnabled="False" />
                    <TabViewItem Header="Note" IsEnabled="False" />
                </TabView>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" Padding="16,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="StatusTextBlock"
                AutomationProperties.LiveSetting="Polite"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                x:Name="SnapshotTextBlock"
                Grid.Column="1" />
        </Grid>
    </Grid>
</UserControl>
